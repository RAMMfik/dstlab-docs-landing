generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  documents Document[]
}

model Document {
  id        String   @id @default(cuid())
  name      String
  fileUrl   String
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])
}